from sklearn.neighbors import NearestNeighbors
import numpy as np

data = np.array([
    [5, 4, 0],
    [4, 0, 5],
    [5, 5, 4],
    [0, 4, 4]
])

# KNN model
model = NearestNeighbors(n_neighbors=2, metric='euclidean')
model.fit(data)

distances, indices = model.kneighbors([data[0]])

print("Nearest Neighbors:", indices)
print("Distances:", distances)